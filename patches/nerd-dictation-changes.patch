+    # Regex to fix VOSK Spanish model merging short function words
+    # with the preceding word. The preceding word must end in a vowel
+    # (or n/r/s/d/l/z — common Spanish word‑final consonants) to avoid
+    # splitting valid longer words like "silla" or "ella".
+    _VOSK_ES_MERGE_RE = re.compile(
+        r"""
+        ([a-záéíóúñ]{2,}[aeiouáéíóúnrsdlz]) # preceding word ending in vowel or common consonant
+        (de|del|el|la|los|las|con|en|        # short function words VOSK tends to merge
+         por|para|que|al|un|una|
+         entre|sobre|hasta|sin|se|no|su)
+        (?![a-záéíóúñ])                       # not followed by more letters
+        """,
+        re.IGNORECASE | re.VERBOSE,
+    )
+
+    def _fix_spanish_merged(text: str) -> str:
+        """Post-process VOSK output: insert spaces between merged Spanish words."""
+        return _VOSK_ES_MERGE_RE.sub(r"\1 \2", text)
+
