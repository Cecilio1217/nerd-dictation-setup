def draw_main(stdscr, idx, items):
    stdscr.erase()
    rows, cols = stdscr.getmaxyx()
    h, w = min(rows, 22), min(cols, 78)
    top = max(0, (rows - h) // 2)
    left = max(0, (cols - w) // 2)
    put = _box(stdscr, top, left, h, w,
               " ndctl — Panel de control ",
               " espacio: toggle · enter: aplicar · esc: cancelar ")

    # Status
    mid = _model_active_id()
    if mid == "canary":
        parts = ["Canary " + ("✓" if service_active() else "✗")]
    else:
        svc = service_active()
        dct = daemon_running() and not is_suspended()
        parts = [f"VOSK {mid}" + (" ✓" if svc else " ✗")]
        if svc:
            parts.append("escuchando" if dct else "pausa")
    put(top + 2, left + 3, "  ·  ".join(parts), curses.A_DIM)

    # Items
    oy = top + 4
    for i, opt in enumerate(items):
        if oy >= top + h - 2:
            break
        pointer = ">" if i == idx else " "
        t = opt["type"]
        if t == "toggle":
            checked = opt.get("_on", opt["get"]())
            box = "[x]" if checked else "[ ]"
            line = f" {pointer} {box} {opt['label']}"
        elif t == "submenu":
            line = f" {pointer}  → {opt['label']}"
        else:
            line = f" {pointer}   {opt['label']}"
        attr = curses.A_REVERSE if i == idx else 0
        put(oy, left + 2, line, attr)
        oy += 1
        put(oy, left + 8, "  " + opt.get("desc", ""), curses.A_DIM)
        oy += 1

    stdscr.refresh()


def main_loop(stdscr, items):
    idx = 0
    for opt in items:
        if opt["type"] == "toggle":
            opt["_on"] = opt["get"]() if callable(opt.get("get")) else opt.get("_on", True)

    while True:
        draw_main(stdscr, idx, items)
        key = stdscr.getch()
        if key in (27, ord("q")):
            return
        elif key in (curses.KEY_UP, ord("k")):
            idx = (idx - 1) % len(items)
        elif key in (curses.KEY_DOWN, ord("j")):
            idx = (idx + 1) % len(items)
        elif key in (ord(" "),):
            opt = items[idx]
            if opt["type"] == "toggle":
                opt["_on"] = not opt.get("_on", True)
            elif opt["type"] == "action":
                opt["action"]()
        elif key in (curses.KEY_ENTER, 10, 13):
            opt = items[idx]
            if opt["type"] == "action":
                opt["action"]()
            elif opt["type"] == "toggle":
                apply_toggles(items)
                return
            elif opt["type"] == "submenu":
                model_menu(stdscr)
                model_menu_item = next((o for o in items if o["type"] == "submenu"), None)
                if model_menu_item:
                    model_menu_item["label"] = f"Motor: {_model_active_id()}"


def apply_toggles(items):
    for opt in items:
        if opt["type"] != "toggle":
            continue
        on_now = callable(opt["get"]) and opt["get"]()
        wanted = opt.get("_on", on_now)
        if callable(opt.get("apply")) and wanted != on_now:
            opt["apply"](wanted)


# ─── Submenú de modelos ─────────────────────────────────

def draw_model_menu(stdscr, idx, models):
    stdscr.erase()
    rows, cols = stdscr.getmaxyx()
    h, w = min(rows, 16), min(cols, 74)
    top = max(0, (rows - h) // 2)
    left = max(0, (cols - w) // 2)
    put = _box(stdscr, top, left, h, w,
               " ndctl — Seleccionar motor ",
               " ↑↓ navegar · enter/espacio: activar · esc: volver ")

    cur_id = _model_active_id()
    oy = top + 2
    for i, m in enumerate(models):
        if oy >= top + h - 2:
            break
        downloaded = _model_downloaded(m)
        active = m["id"] == cur_id
        radio = "◉" if active else "○"
        status = " ✓" if downloaded else " ✗"
        pointer = ">" if i == idx else " "
        line = f" {pointer} {radio} {m['name']}{status}  {m['size']}"
        attr = curses.A_REVERSE if i == idx else 0
        put(oy, left + 2, line, attr)
        oy += 1
        desc = m["desc"]
        if not downloaded:
            desc += "  [Pulsa Enter para descargar]"
        put(oy, left + 6, " " + desc, curses.A_DIM)
        oy += 1

    stdscr.refresh()


def model_menu(stdscr):
    idx = 0
    while True:
        draw_model_menu(stdscr, idx, MODELS)
        key = stdscr.getch()

        if key in (27, ord("q")):
            return

        elif key in (curses.KEY_UP, ord("k")):
            idx = (idx - 1) % len(MODELS)
        elif key in (curses.KEY_DOWN, ord("j")):
            idx = (idx + 1) % len(MODELS)

        elif key in (curses.KEY_ENTER, 10, 13, ord(" ")):
            m = MODELS[idx]
            active_id = _model_active_id()
            if m["id"] == active_id:
                return  # Already active, just leave
            if not _model_downloaded(m):
                if m.get("url"):
                    # Download in a sub-screen
                    stdscr.erase()
                    rows, cols = stdscr.getmaxyx()
                    status_text = f"Descargando {m['name']}..."
                    stdscr.addstr(rows // 2, (cols - len(status_text)) // 2, status_text)
                    stdscr.refresh()
                    ok = download_model(m)
                    if not ok:
                        status_text = f"Error descargando {m['name']}"
                        stdscr.addstr(rows // 2 + 1, (cols - len(status_text)) // 2, status_text, curses.A_DIM)
                        stdscr.refresh()
                        time.sleep(1.5)
                        continue
                else:
                    continue
            # Switch to model
            switch_to_model(m["id"])
            return


def main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()
    items = list(ITEMS)
    main_loop(stdscr, items)


if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        sys.exit(0)
