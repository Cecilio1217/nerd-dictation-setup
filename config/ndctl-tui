# ─── Helpers básicos ────────────────────────────────────

def _systemctl(*args):
    subprocess.run(["systemctl", "--user", *args],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def _nerd_cmd(*args):
    subprocess.run([str(NERD), *args],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def _model_downloaded(m: dict) -> bool:
    """Check if a model's check_file exists."""
    f = m.get("check_file") or m.get("path")
    return f is not None and f.exists()


def _model_active_id() -> str:
    """Detect current engine: small, large, or canary."""
    try:
        out = subprocess.check_output(
            ["systemctl", "--user", "is-active", CANARY_SERVICE],
            stderr=subprocess.DEVNULL,
        ).decode().strip()
        if out == "active":
            return "canary"
    except Exception:
        pass
    if SERVICE_FILE.exists():
        content = SERVICE_FILE.read_text()
        if "vosk-model-es-0.42" in content:
            return "large"
    return "small"


def service_active() -> bool:
    try:
        svc = CANARY_SERVICE if _model_active_id() == "canary" else SERVICE
        out = subprocess.check_output(
            ["systemctl", "--user", "is-active", svc], stderr=subprocess.DEVNULL
        ).decode().strip()
        return out == "active"
    except Exception:
        return False


def daemon_running() -> bool:
    if not COOKIE.exists():
        return False
    try:
        pid = int(COOKIE.read_text().strip())
        os.kill(pid, 0)
        return True
    except Exception:
        return False


def is_suspended() -> bool:
    return STATE_FILE.exists() and STATE_FILE.read_text().strip() == "suspended"


def service_enabled() -> bool:
    try:
        out = subprocess.check_output(
            ["systemctl", "--user", "is-enabled", SERVICE], stderr=subprocess.DEVNULL
        ).decode().strip()
        return out == "enabled"
    except Exception:
        return False


def filter_loaded() -> bool:
    try:
        out = subprocess.check_output(
            ["pactl", "list", "short", "modules"], stderr=subprocess.DEVNULL
        ).decode()
        return "noise_reduced_mic" in out or "filter-chain" in out
    except Exception:
        return False


def has_config_flag() -> bool:
    """Check if the service file has --config flag (command processing)."""
    if not SERVICE_FILE.exists():
        return True
    content = SERVICE_FILE.read_text()
    return "--config" in content and not any(
        line.strip().startswith("#") and "--config" in line
        for line in content.splitlines()
    )


def resume_dictation():
    _nerd_cmd("resume", "--cookie", str(COOKIE))
    STATE_FILE.write_text("listening")


def suspend_dictation():
    _nerd_cmd("suspend", "--cookie", str(COOKIE))
    STATE_FILE.write_text("suspended")


def toggle_transcribe_only(on: bool):
    """Toggle --config flag in service file."""
    if not SERVICE_FILE.exists():
        return
    content = SERVICE_FILE.read_text()
    lines = content.splitlines()
    new_lines = []
    for line in lines:
        if "--config" in line:
            if on:
                stripped = line.lstrip()
                if not stripped.startswith("#"):
                    new_lines.append("#" + line)
                    continue
            else:
                new_lines.append(line.lstrip("#"))
                continue
        new_lines.append(line)
    SERVICE_FILE.write_text("\n".join(new_lines) + "\n")
    _systemctl("daemon-reload")
    restart_service()


def toggle_filter(on: bool):
    """Toggle PipeWire filter-chain."""
    filter_conf = Path.home() / ".config" / "pipewire" / "filter-chain.conf.d" / "noise-reduction-source.conf"
    if not filter_conf.exists():
        return
    if on:
        _systemctl("restart", "pipewire")
    else:
        backup = filter_conf.with_name("noise-reduction-source.conf.disabled")
        if not backup.exists():
            shutil.move(str(filter_conf), str(backup))
        _systemctl("restart", "pipewire")


def toggle_auto_silence(on: bool):
    """Toggle idle-time in service file."""
    if not SERVICE_FILE.exists():
        return
    content = SERVICE_FILE.read_text()
    if on:
        content = content.replace("--idle-time 0.05", "--idle-time 0.5")
    else:
        content = content.replace("--idle-time 0.5", "--idle-time 0.05")
    SERVICE_FILE.write_text(content)
    _systemctl("daemon-reload")
    restart_service()


# ─── Acciones ───────────────────────────────────────────

def start_service():
    if _model_active_id() == "canary":
        _systemctl("start", CANARY_SERVICE)
    else:
        _systemctl("start", SERVICE)


def stop_service():
    _systemctl("stop", SERVICE)
    _systemctl("stop", CANARY_SERVICE)


def restart_service():
    stop_service()
    time.sleep(0.5)
    start_service()
    time.sleep(0.5)


def switch_to_model(model_id: str) -> bool:
    """Switch to a model. Returns True on success."""
    cur = _model_active_id()
    if model_id == cur:
        return True
    if model_id == "canary":
        _systemctl("stop", SERVICE)
        _systemctl("start", CANARY_SERVICE)
    else:
        _systemctl("stop", CANARY_SERVICE)
        if SERVICE_FILE.exists():
            content = SERVICE_FILE.read_text()
            if model_id == "large":
                content = content.replace("vosk-model-small-es", "vosk-model-es-0.42")
            else:
                content = content.replace("vosk-model-es-0.42", "vosk-model-small-es")
            SERVICE_FILE.write_text(content)
            _systemctl("daemon-reload")
        _systemctl("start", SERVICE)
    time.sleep(0.5)
    return True


def download_model(m: dict, progress_callback=None) -> bool:
    """Download and extract a model. Shows progress via callback."""
    url = m.get("url")
    dest = m.get("download_dir")
    zip_name = m.get("zip_name")
    if not url or not dest or not zip_name:
        return False
    dest.mkdir(parents=True, exist_ok=True)
    zip_path = dest / zip_name
    try:
        if progress_callback:
            progress_callback(f"Descargando {m['name']}...")
        r = subprocess.run(
            ["wget", "-O", str(zip_path), url],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        if r.returncode != 0:
            return False
        if progress_callback:
            progress_callback(f"Extrayendo {m['name']}...")
        r = subprocess.run(
            ["unzip", "-o", str(zip_path), "-d", str(dest)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        zip_path.unlink(missing_ok=True)
        if r.returncode != 0:
            return False
        # Handle subdirectory (zip extracts to vosk-model-*.*.*/)
        for p in dest.iterdir():
            if p.is_dir() and p.name.startswith("vosk-model-") and p != m["path"]:
                if p.name.endswith(zip_name.replace(".zip", "")):
                    # Move contents to expected path
                    if not m["path"].exists():
                        p.rename(m["path"])
                    else:
                        shutil.copytree(p, m["path"], dirs_exist_ok=True)
                        shutil.rmtree(p)
                break
        return True
    except Exception:
        return False


# ─── Render helpers ─────────────────────────────────────

def _box(stdscr, top, left, h, w, title, footer):
    """Draw rounded box with title and footer."""
    tl, tr = "╭", "╮"
    bl, br = "╰", "╯"
    hb, vb = "─", "│"

    def put(y, x, ch, attr=0):
        try:
            if 0 <= y < stdscr.getmaxyx()[0] and 0 <= x < stdscr.getmaxyx()[1]:
                stdscr.addstr(y, x, ch, attr)
        except curses.error:
            pass

    put(top, left, tl, curses.A_BOLD)
    put(top, left + w - 1, tr, curses.A_BOLD)
    put(top + h - 1, left, bl, curses.A_BOLD)
    put(top + h - 1, left + w - 1, br, curses.A_BOLD)
    for x in range(left + 1, left + w - 1):
        put(top, x, hb)
        put(top + h - 1, x, hb)
    for y in range(top + 1, top + h - 1):
        put(y, left, vb)
        put(y, left + w - 1, vb)
    put(top, left + 2, title, curses.A_BOLD)
    put(top + h - 1, left + 2, footer, curses.A_DIM)
    return put


