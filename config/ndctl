#!/bin/bash
# ndctl — nerd-dictation CLI control
# Uso: ndctl <comando> [args]
#      ndctl menu   (menú interactivo con dialog/whiptail)

set -euo pipefail

NERD="$HOME/nerd-dictation/nerd-dictation"
COOKIE="/tmp/nerd-dictation-cookie"
STATE_FILE="/tmp/nerd-dictation-state"
SERVICE="nerd-dictation.service"

if [ ! -f "$NERD" ]; then
    NERD="$HOME/Documentos/proyectos/transcripcion/nerd-dictation/nerd-dictation"
fi

# ─── helpers ────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}══ $1 ══${NC}"; }

service_active() {
    systemctl --user is-active "$SERVICE" 2>/dev/null | grep -q "active"
}

daemon_running() {
    [ -f "$COOKIE" ] && kill -0 "$(cat "$COOKIE")" 2>/dev/null
}

# ─── commands ───────────────────────────────────────────────
cmd_status() {
    title "Estado"
    if service_active; then
        info "Servicio: ACTIVO"
    else
        warn "Servicio: INACTIVO"
    fi
    if daemon_running; then
        info "Daemon:  CORRIENDO (pid $(cat "$COOKIE"))"
    else
        warn "Daemon:  DETENIDO"
    fi
    if [ -f "$STATE_FILE" ]; then
        info "Toggle:  $(cat "$STATE_FILE")"
    else
        warn "Toggle:  no iniciado"
    fi
    echo ""
    systemctl --user status "$SERVICE" 2>&1 | head -10
}

cmd_start() {
    if service_active; then
        warn "El servicio ya está activo"
    else
        systemctl --user start "$SERVICE"
        info "Servicio iniciado"
    fi
}

cmd_stop() {
    if service_active; then
        systemctl --user stop "$SERVICE"
        info "Servicio detenido"
    else
        warn "El servicio ya está inactivo"
    fi
}

cmd_restart() {
    systemctl --user restart "$SERVICE"
    info "Servicio reiniciado"
}

cmd_toggle() {
    "$HOME/.local/bin/nerd-dictation-toggle"
}

cmd_suspend() {
    if daemon_running; then
        "$NERD" suspend --cookie "$COOKIE"
        echo "suspended" > "$STATE_FILE"
        info "Dictado suspendido"
    else
        error "Daemon no está corriendo"
    fi
}

cmd_resume() {
    if daemon_running; then
        "$NERD" resume --cookie "$COOKIE"
        echo "listening" > "$STATE_FILE"
        info "Dictado reanudado"
    else
        error "Daemon no está corriendo"
    fi
}

cmd_logs() {
    journalctl --user -u "$SERVICE" -f "${@:2}"
}

cmd_enable() {
    systemctl --user enable "$SERVICE"
    info "Servicio habilitado para inicio automático"
}

cmd_disable() {
    systemctl --user disable "$SERVICE"
    info "Servicio deshabilitado para inicio automático"
}

cmd_model() {
    local dir
    if [ "$#" -eq 0 ]; then
        echo "Modelo actual:"
        systemctl --user show -P ExecStart "$SERVICE" 2>/dev/null \
            | tr ' ' '\n' | grep vosk-model
        echo ""
        echo "Usá: ndctl model <nombre>"
        echo "  ndctl model small    → vosk-model-small-es"
        echo "  ndctl model large    → vosk-model-es-0.42"
        echo "  ndctl model list     → listar modelos disponibles"
        return
    fi
    case "${1:-}" in
        small)
            dir="vosk-model-small-es"
            ;;
        large)
            dir="vosk-model-es-0.42"
            ;;
        list)
            echo "Modelos en $HOME/nerd-dictation/:"
            ls -d "$HOME/nerd-dictation/vosk-model"* 2>/dev/null || echo "  (ninguno)"
            echo ""
            echo "Modelos en $HOME/Documentos/proyectos/transcripcion/nerd-dictation/:"
            ls -d "$HOME/Documentos/proyectos/transcripcion/nerd-dictation/vosk-model"* 2>/dev/null || echo "  (ninguno)"
            return
            ;;
        *)
            error "Modelo desconocido: $1. Usá: small, large, list"
            return 1
            ;;
    esac
    # Encontrar la ruta completa
    local full_path=""
    for base in "$HOME/nerd-dictation/$dir" "$HOME/Documentos/proyectos/transcripcion/nerd-dictation/$dir"; do
        if [ -d "$base" ]; then
            full_path="$base"
            break
        fi
    done
    if [ -z "$full_path" ]; then
        error "Modelo no encontrado: $dir"
        return 1
    fi
    # Actualizar service para que apunte al nuevo modelo (editar en caliente)
    local curr_path
    curr_path=$(systemctl --user show -P ExecStart "$SERVICE" 2>/dev/null \
        | grep -oP '--vosk-model-dir \K\S+' || echo "")
    if [ -n "$curr_path" ] && [ "$curr_path" != "$full_path" ]; then
        local svc_file="$HOME/.config/systemd/user/$SERVICE"
        if [ -f "$svc_file" ]; then
            sed -i "s|$curr_path|$full_path|g" "$svc_file"
            systemctl --user daemon-reload
            info "Service actualizado al modelo: $dir"
            warn "Ejecutá 'ndctl restart' para aplicar el cambio"
        fi
    else
        info "Ya está usando el modelo: $dir"
    fi
}

cmd_help() {
    echo "ndctl — Control de nerd-dictation"
    echo ""
    echo "Uso: ndctl <comando> [args]"
    echo ""
    echo "Servicio:"
    echo "  status               Estado del servicio y daemon"
    echo "  start                Iniciar servicio"
    echo "  stop                 Detener servicio"
    echo "  restart              Reiniciar servicio"
    echo "  enable               Habilitar en inicio de sesión"
    echo "  disable              Deshabilitar en inicio de sesión"
    echo ""
    echo "Dictado:"
    echo "  toggle               Pausar/reanudar dictado"
    echo "  suspend              Suspender dictado"
    echo "  resume               Reanudar dictado"
    echo ""
    echo "Configuración:"
    echo "  model [small|large|list]  Ver/cambiar modelo VOSK"
    echo ""
    echo "Interfaz:"
    echo "  menu                 Panel TUI (↑↓·Espacio·Enter·Esc)"
    echo "                       Submenú modelos: seleccionar y descargar"
    echo "  logs [-f]            Ver logs del servicio"
    echo "  help                 Esta ayuda"
}

cmd_menu() {
    # Lanza la TUI estilo Gentle AI (Python + curses)
    local tui="$HOME/.local/bin/ndctl-tui"
    if [ ! -x "$tui" ]; then
        error "TUI no encontrada en $tui"
        exit 1
    fi
    exec python3 "$tui"
}

# ─── dispatch ───────────────────────────────────────────────
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    status)   cmd_status ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    toggle)   cmd_toggle ;;
    suspend)  cmd_suspend ;;
    resume)   cmd_resume ;;
    enable)   cmd_enable ;;
    disable)  cmd_disable ;;
    logs)     cmd_logs "$@" ;;
    model)    cmd_model "$@" ;;
    menu)     cmd_menu ;;
    help|--help|-h) cmd_help ;;
    *)
        error "Comando desconocido: $CMD"
        cmd_help
        exit 1
        ;;
esac
